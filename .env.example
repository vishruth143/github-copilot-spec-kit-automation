# Copy this file to `.env` and fill in real values for your local machine.
# NEVER commit `.env` (it is excluded via .gitignore) and NEVER put real
# secrets in this .env.example file — only placeholder/empty values.

# --- Framework-wide selection (all optional; can also be passed as CLI flags) ---
# ENV selects the active environment profile: dev | test | stage | prod
ENV=dev
# BROWSER selects the engine: chromium | firefox | webkit
BROWSER=chromium
# HEADLESS: true | false
HEADLESS=true

# --- Sample application: internet_herokuapp (Login) base URLs per environment ---
INTERNET_HEROKUAPP_URL__DEV=
INTERNET_HEROKUAPP_URL__TEST=
INTERNET_HEROKUAPP_URL__STAGE=
INTERNET_HEROKUAPP_URL__PROD=

# --- Sample application: internet_herokuapp (Login) test account (non-production only) ---
INTERNET_HEROKUAPP_USERNAME=
INTERNET_HEROKUAPP_PASSWORD=

# --- Sample application: demo_playwright base URLs per environment ---
DEMO_PLAYWRIGHT_BASE_URL__DEV=
DEMO_PLAYWRIGHT_BASE_URL__TEST=
DEMO_PLAYWRIGHT_BASE_URL__STAGE=
DEMO_PLAYWRIGHT_BASE_URL__PROD=
